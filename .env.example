# Application
ENVIRONMENT=development
API_KEY=your-api-key-here
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/talent_engine

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=resumes

# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://your-instance.cognitiveservices.azure.com/
AZURE_DI_KEY=your-key-here

# AI Models
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-key-here
HF_API_TOKEN=your-huggingface-token-here

# Embedding
OPENAI_API_KEY=your-openai-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Azure OpenAI — Embeddings
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01